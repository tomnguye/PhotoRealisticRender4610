import bpy
import os

EXPORT_DIR = "/home/ryan/4610/PhotoRealisticRender4610/models/gltf"

os.makedirs(EXPORT_DIR, exist_ok=True)

# Deselect everything first
bpy.ops.object.select_all(action="DESELECT")

for obj in bpy.data.objects:

    # Skip cameras/lights/etc
    if obj.type != "MESH":
        continue

    print(f"Exporting: {obj.name}")

    # Select only this object
    bpy.ops.object.select_all(action="DESELECT")
    obj.select_set(True)
    bpy.context.view_layer.objects.active = obj

    # Apply transforms so exported coordinates match viewport
    bpy.ops.object.transform_apply(location=True, rotation=True, scale=True)

    # Safe filename
    safe_name = bpy.path.clean_name(obj.name)

    export_path = os.path.join(EXPORT_DIR, f"{safe_name}.glb")

    bpy.ops.export_scene.gltf(
        filepath=export_path,
        export_format="GLB",
        use_selection=True,
        export_texcoords=True,
        export_normals=True,
        export_tangents=True,
        export_materials="EXPORT",
        export_yup=True,
        export_apply=False,
    )

    print(f"Saved: {export_path}")

print("Done.")
